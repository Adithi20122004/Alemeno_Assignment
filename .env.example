APP_NAME=Transaction Cleaner
APP_ENV=development
LOG_LEVEL=INFO

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=txndb
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/txndb

REDIS_HOST=redis
REDIS_PORT=6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

GEMINI_API_KEY=replace_me_with_your_google_ai_studio_key
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_BASE_SECONDS=2

UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=20
